apiVersion: v1
kind: Secret
metadata:
  name: employee-hub-secrets
  namespace: employee-hub
type: Opaque
stringData:
  POSTGRES_USER: your_db_user
  POSTGRES_PASSWORD: your_db_password
  POSTGRES_DB: employee_db
  DATABASE_HOST: your-rds-endpoint.rds.amazonaws.com
  DATABASE_URL: postgres://your_db_user:your_db_password@your-rds-endpoint.rds.amazonaws.com:5432/employee_db
  DATABASE_SSL: "true"
  CLIENT_ORIGIN: https://your-domain.com
  ADMIN_EMAIL: admin@your-company.example
  ADMIN_PASSWORD: replace-with-a-strong-password
